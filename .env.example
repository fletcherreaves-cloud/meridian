# Meridian — environment variables
# Copy this to .env.local (gitignored) and fill in your values.
# For GitHub Pages CI: add these as repository secrets (Settings → Secrets → Actions).

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=eyJ...

# Leave both blank to run in local-only mode (localStorage only, no auth, no sync)
